{
  "source_ref": "payment-rules@0.1.0",
  "schema_version": "1.0",
  "default_currency": "VND",
  "match_priority": [
    "code",
    "group",
    "keyword"
  ],
  "rules": [
    {
      "rule_id": "PAY.OUT_OF_SCOPE.001",
      "enabled": true,
      "description_vi": "Khoản ngoài phạm vi thanh toán BHYT",
      "rule_kind": "out_of_scope",
      "item_types": [
        "service",
        "drug",
        "supply"
      ],
      "suggested_action": "reject",
      "severity": "reject",
      "impact_formula": "full_line_amount",
      "effective_from": "2025-01-01",
      "effective_to": null,
      "legal_basis": [
        "TT39/2024/TT-BYT"
      ],
      "matchers": [
        {
          "match_type": "code",
          "item_type": "service",
          "values": []
        },
        {
          "match_type": "code",
          "item_type": "drug",
          "values": []
        },
        {
          "match_type": "code",
          "item_type": "supply",
          "values": []
        },
        {
          "match_type": "keyword",
          "item_type": "service",
          "values": []
        },
        {
          "match_type": "keyword",
          "item_type": "drug",
          "values": []
        },
        {
          "match_type": "keyword",
          "item_type": "supply",
          "values": []
        }
      ]
    },
    {
      "rule_id": "PAY.LIMIT.COVERAGE_PERCENT.001",
      "enabled": true,
      "description_vi": "Giới hạn tỷ lệ thanh toán",
      "rule_kind": "coverage_percent",
      "item_types": [
        "service",
        "drug",
        "supply"
      ],
      "suggested_action": "reduce",
      "severity": "warning",
      "impact_formula": "line_amount * (1 - coverage_percent)",
      "effective_from": "2025-01-01",
      "effective_to": null,
      "legal_basis": [],
      "matchers": [
        {
          "match_type": "code",
          "item_type": "drug",
          "entries": []
        },
        {
          "match_type": "group",
          "item_type": "supply",
          "entries": []
        }
      ]
    },
    {
      "rule_id": "PAY.LIMIT.UNIT_PRICE_MAX.001",
      "enabled": true,
      "description_vi": "Giới hạn đơn giá thanh toán tối đa",
      "rule_kind": "unit_price_max",
      "item_types": [
        "service",
        "drug",
        "supply"
      ],
      "suggested_action": "reduce",
      "severity": "warning",
      "impact_formula": "(actual_unit_price - unit_price_max) * quantity",
      "effective_from": "2025-01-01",
      "effective_to": null,
      "legal_basis": [],
      "matchers": [
        {
          "match_type": "code",
          "item_type": "service",
          "entries": []
        },
        {
          "match_type": "code",
          "item_type": "drug",
          "entries": []
        },
        {
          "match_type": "code",
          "item_type": "supply",
          "entries": []
        }
      ]
    },
    {
      "rule_id": "PAY.LIMIT.QUANTITY_MAX.001",
      "enabled": true,
      "description_vi": "Giới hạn số lượng thanh toán tối đa",
      "rule_kind": "quantity_max",
      "item_types": [
        "service",
        "drug",
        "supply"
      ],
      "suggested_action": "reduce",
      "severity": "warning",
      "impact_formula": "max(0, quantity - quantity_max) * actual_unit_price",
      "effective_from": "2025-01-01",
      "effective_to": null,
      "legal_basis": [],
      "matchers": [
        {
          "match_type": "code",
          "item_type": "service",
          "entries": []
        },
        {
          "match_type": "group",
          "item_type": "drug",
          "entries": []
        }
      ]
    },
    {
      "rule_id": "PAY.LIMIT.AMOUNT_MAX.001",
      "enabled": true,
      "description_vi": "Giới hạn tổng tiền thanh toán tối đa cho dòng chi phí",
      "rule_kind": "amount_max",
      "item_types": [
        "service",
        "drug",
        "supply"
      ],
      "suggested_action": "reduce",
      "severity": "warning",
      "impact_formula": "max(0, line_amount - amount_max)",
      "effective_from": "2025-01-01",
      "effective_to": null,
      "legal_basis": [],
      "matchers": [
        {
          "match_type": "code",
          "item_type": "service",
          "entries": []
        }
      ]
    }
  ],
  "entry_schema": {
    "match_type": "code|group|keyword",
    "item_type": "service|drug|supply",
    "match_value": "string",
    "group_code": "string|null",
    "keyword": "string|null",
    "coverage_percent": "number|null",
    "unit_price_max": "number|null",
    "quantity_max": "number|null",
    "amount_max": "number|null",
    "legal_basis": [
      "string"
    ],
    "effective_from": "date|null",
    "effective_to": "date|null",
    "notes": "string|null"
  }
}
